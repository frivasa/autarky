# cd wrap to have directory history (cd ←→  dc)
# (zoxide sucks balls because it guesses what's best for you instead of being straightforward like fuzzy search)
cd() {
    local target
    if [ $# -eq 0 ]; then
        target="$HOME"
    else
        target=$(builtin cd -- "$@" 2>/dev/null && pwd) || { echo "cd: no such directory: $*" >&2; return 1; }
    fi
    builtin pushd "$target" >/dev/null || return
}

dc() {
    local dir
    dir=$(dirs -p -l | awk '!seen[$0]++' | fzf --reverse --height 40%) || return
    builtin cd -- "$dir" || return
}


# edit pixi env config to not alter ps1
function pixi_trim_ps1(){
  pixi config set shell.change-ps1 false
}

# change image for fastfetch
function fastfetch_switch_waifu(){
  # defaults to sfw/non-animated
  # n/sfw gif/nongif
  kind=${1:-sfw}
  animated=${2:-nongif}
  source ~/.config/fastfetch/change_waifu.sh $kind $animated
}

# short nnn command that cds after quitting
n() {
    export NNN_TMPFILE="${XDG_CONFIG_HOME:-$HOME/.config}/nnn/.lastd"
    export NNN_TRASH=trash-put

    nnn -C "$@"

    if [ -f "$NNN_TMPFILE" ]; then
        . "$NNN_TMPFILE"
        rm -f "$NNN_TMPFILE"
    fi
}

