#!/bin/bash
set -e

MODE="${1:-selection}"

DIR="$HOME/Pictures"
mkdir -p "$DIR"

FILE="$DIR/screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"

case "$MODE" in
  selection)
    GEOM="$(slurp)"
    grim -g "$GEOM" "$FILE"
    ;;

  screen)
    # pick output/monitor
    GEOM="$(slurp -o)"
    grim "$FILE"
    ;;

  *)
    echo "Usage: $0 [selection|screen]"
    exit 1
    ;;
esac

# validate output
if [[ ! -s "$FILE" ]]; then
  notify-send "Screenshot failed" "No image produced"
  exit 1
fi

satty --filename "$FILE" \
  --early-exit \
  --actions-on-enter save-to-clipboard \
  --save-after-copy \
  --copy-command 'wl-copy'


