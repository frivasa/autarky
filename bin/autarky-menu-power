#!/bin/bash

show_power_menu() {
  local menu_options="’ĆŻ Lock
¾░żä Suspend
’ŹÖ Relaunch
¾░£ē Restart
¾░Éź Shutdown"
  local selection
  selection=$(printf '%s\n' "$menu_options" | fuzzel --dmenu -w 15 -l 10 -p "" --mesg "Power Options" --hide-prompt )
  case "$selection" in
  *Lock*) hyprlock ;;
  *Suspend*) systemctl suspend ;;
  *Relaunch*) uwsm stop ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  esac
}

show_power_menu
